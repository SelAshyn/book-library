# Django
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-change-this-in-production
DEBUG=False

# Database (PostgreSQL)
DB_NAME=booklibrary
DB_USER=booklibrary
DB_PASSWORD=your-secure-database-password
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Allowed hosts — comma-separated (include your Railway domain)
ALLOWED_HOSTS=localhost,127.0.0.1,https://book-library-backend-467u.onrender.com

# Firebase — path to service account JSON (local dev)
FIREBASE_CREDENTIALS=firebase-credentials.json

# Firebase — base64-encoded service account JSON (cloud deployment)
# Generate with: python -c "import base64; print(base64.b64encode(open('firebase-credentials.json','rb').read()).decode())"
FIREBASE_CREDENTIALS_BASE64=
